# Copy this file to .env and add your config values

# Firebase (Optional - only needed if using Firebase instead of MongoDB backend)
VITE_FIREBASE_API_KEY=your_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_auth_domain
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Backend API URL (Required - point to your deployed backend)
VITE_API_BASE_URL=https://your-backend-domain.vercel.app/api

# ImgBB API Key (Optional - defaults to built-in key)
VITE_IMGBB_API_KEY=your_imgbb_api_key
