# Option 1: Use a single connection string (recommended for Vercel/cloud)
# MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/drariful_cms?retryWrites=true&w=majority

# Option 2: Use individual components (auto-builds the URI)
DB_USERNAME=your_mongodb_username
DB_PASSWORD=your_mongodb_password
DB_CLUSTER=your_cluster_url_without_https
DB_NAME=drariful_cms

# Server
PORT=5000

# Security
JWT_SECRET=your_jwt_secret_key_here
ADMIN_EMAIL=admin@drariful.com
ADMIN_PASSWORD=your_secure_admin_password
